# ============================================
# STELLAR PORTFOLIO REBALANCER - FRONTEND ENV
# ============================================

# ============================================
# REQUIRED SETTINGS
# ============================================

# Backend API base URL
VITE_API_URL=http://localhost:3001

# WebSocket base (optional; used when client reads this from env)
VITE_WS_URL=ws://localhost:3001

# ============================================
# OPTIONAL SETTINGS
# ============================================

# API segment after /api/ (default v1 → /api/v1/*). See frontend/src/config/apiVersion.ts
VITE_API_VERSION=v1
# Emergency rollback: call deprecated /api/* (server may send Deprecation headers)
VITE_USE_LEGACY_API=false

# React Query Devtools (also when import.meta.env.DEV)
VITE_ENABLE_QUERY_DEVTOOLS=false

VITE_E2E_MOCK_WALLET=false
# VITE_COINGECKO_API_KEY=

# ============================================
# LEGACY / COMPATIBILITY (Optional)
# ============================================

VITE_STELLAR_NETWORK=testnet
VITE_CONTRACT_ADDRESS=CA...
VITE_REFLECTOR_ADDRESS=CDSWUUXGPWDZG76ISK6SUCVPZJMD5YUV66J2FXFXFGDX25XKZJIEITAO
VITE_DEMO_MODE=true
VITE_DEBUG_API=false
