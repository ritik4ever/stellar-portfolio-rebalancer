# ============================================
# STELLAR PORTFOLIO REBALANCER - FRONTEND ENV
# ============================================

# ============================================
# REQUIRED SETTINGS
# ============================================
# 🚀 REQUIRED SETTINGS
# ============================================

# Backend API base URL
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
# API version prefix (used to construct endpoints like /api/v1/*)
VITE_API_VERSION=v1

# ============================================
# ⚙️ OPTIONAL SETTINGS
# ============================================

# ============================================
# OPTIONAL SETTINGS
# ============================================
# API segment after /api/ (default v1 → app calls /api/v1/*). See frontend/src/config/apiVersion.ts.
VITE_API_VERSION=v1
# Emergency rollback only: use deprecated unversioned /api/* (Deprecation headers from server).
VITE_USE_LEGACY_API=false
# Enable mock wallet for testing (E2E)
VITE_E2E_MOCK_WALLET=false

# ============================================
# LEGACY / COMPATIBILITY (Optional)
# ============================================

# Optional: only needed if frontend directly calls CoinGecko
# VITE_COINGECKO_API_KEY=

# ============================================
# 🧩 LEGACY / COMPATIBILITY (Optional)
# ============================================

# Not required for current runtime – used in older setups

# Stellar network (testnet or mainnet)
VITE_STELLAR_NETWORK=testnet

# Soroban contract address (starts with 'C...')
VITE_CONTRACT_ADDRESS=CA...

# Reflector oracle contract address
VITE_REFLECTOR_ADDRESS=CDSWUUXGPWDZG76ISK6SUCVPZJMD5YUV66J2FXFXFGDX25XKZJIEITAO

VITE_DEMO_MODE=true
VITE_DEBUG_API=false