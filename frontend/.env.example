# VITE_WS_PATH=

# OPTIONAL SETTINGS (feature-specific/test-only)
VITE_E2E_MOCK_WALLET=false
VITE_COINGECKO_API_KEY=

# Legacy/non-runtime values kept for compatibility with older setups
