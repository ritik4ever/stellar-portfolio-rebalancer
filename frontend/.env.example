# ============================================
# STELLAR PORTFOLIO REBALANCER - FRONTEND ENV
# ============================================

# ============================================
# REQUIRED SETTINGS
# ============================================

# Backend API base URL
VITE_API_URL=http://localhost:3001

# WebSocket base (optional; used when client reads this from env)
VITE_WS_URL=ws://localhost:3001

# ============================================
# OPTIONAL SETTINGS
# ============================================

# API version prefix (default: v1 → /api/v1). Set to empty string for legacy /api
VITE_API_VERSION=v1

# Set to true to force legacy /api/* namespace (overrides VITE_API_VERSION)
VITE_USE_LEGACY_API=false

# WebSocket path (default: /socket.io or as configured by backend)
VITE_WS_PATH=/socket.io

# CoinGecko API key (optional; enables higher rate limits for price feeds)
VITE_COINGECKO_API_KEY=

# Enable React Query Devtools (development only)
VITE_ENABLE_QUERY_DEVTOOLS=false

# Enable verbose price feed debugging in browser console
VITE_ENABLE_BROWSER_PRICE_DEBUG=false

# Frontend Sentry
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
# Sentry environment tag (should match the deployed tier)
VITE_SENTRY_ENVIRONMENT=development
# Sentry release tag (use the full git SHA for the deployed build)
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# E2E test mock wallet address (used by Playwright tests)
VITE_E2E_MOCK_WALLET=

# ============================================
# ANALYTICS (Optional — self-hosted Umami)
# ============================================

# Set to true to enable privacy-respecting analytics (cookie-free, no PII).
# Automatically disabled when VITE_DEMO_MODE=true.
VITE_ANALYTICS_ENABLED=false

# URL of your self-hosted Umami instance (e.g. https://analytics.example.com)
VITE_ANALYTICS_URL=

# Umami website ID (found in Umami dashboard → Settings → Websites)
VITE_ANALYTICS_SITE_ID=

# ============================================
# LEGACY / COMPATIBILITY (Optional)
# ============================================

VITE_STELLAR_NETWORK=testnet
VITE_CONTRACT_ADDRESS=CA...
VITE_REFLECTOR_ADDRESS=CDSWUUXGPWDZG76ISK6SUCVPZJMD5YUV66J2FXFXFGDX25XKZJIEITAO
VITE_DEMO_MODE=true
VITE_DEBUG_API=false
