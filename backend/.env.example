# ============================================
# REQUIRED SETTINGS
# ============================================

# --- Core runtime ---
# Runtime mode for startup validation and feature gating | enum(development|test|production) | # Optional (default: development)
NODE_ENV=development
# HTTP API port used by the backend server | integer | # Optional (default: 3001)
PORT=3001

# ============================================
# OPTIONAL SETTINGS
# ============================================

# --- Stellar network and contract wiring ---
# Stellar network selector for Horizon/RPC defaults | enum(testnet|mainnet) | # Optional (default: testnet)
STELLAR_NETWORK=testnet
# Horizon API base URL used by backend Stellar services | URL | # Required
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Soroban contract address used for portfolio operations | Stellar contract strkey (C...) | # Required
STELLAR_CONTRACT_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# Alias for STELLAR_CONTRACT_ADDRESS (must match if both are set) | Stellar contract strkey (C...) | # Optional (default: empty)
CONTRACT_ADDRESS=
# Signer secret used for backend-signed rebalances (required unless demo fallback mode is active) | Stellar secret strkey (S...) | # Required
STELLAR_REBALANCE_SECRET=SBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB
# Alias for STELLAR_REBALANCE_SECRET | Stellar secret strkey (S...) | # Optional (default: empty)
STELLAR_SECRET_KEY=
# Allow signer account to differ from portfolio owner in execution paths | boolean | # Optional (default: false)
REBALANCE_ALLOW_SIGNER_MISMATCH=false
# JSON issuer map for non-native assets (symbol -> issuer public key) | JSON object | # Optional (default: bundled mapping)
STELLAR_ASSET_ISSUERS={"USDC":"GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5","BTC":"GAUTUYY2THLF7SGITDFMXJVYH3LHDSMGEAKSBU267M2K7A3W543CKUEF"}

# --- Database ---
# PostgreSQL connection string for migration/runtime pool | connection string | # Optional (default: empty; SQLite fallback)
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_portfolio
# PostgreSQL host (used with PGUSER + PGDATABASE) | string | # Optional (default: empty)
PGHOST=
# PostgreSQL port | integer | # Optional (default: 5432)
PGPORT=5432
# PostgreSQL username | string | # Optional (default: empty)
PGUSER=
# PostgreSQL password | string | # Optional (default: empty)
PGPASSWORD=
# PostgreSQL database name | string | # Optional (default: empty)
PGDATABASE=
# CI marker used by tooling and env validation checks | string | # Optional (default: empty)
CI=
# SQLite database file path for local/test usage | filesystem path | # Optional (default: ./data/portfolio.db)
DB_PATH=./data/portfolio.db

# --- Price feed ---
# CoinGecko API key for production-grade rate limits | string | # Optional (default: empty)
COINGECKO_API_KEY=
# In-memory price cache TTL | integer milliseconds | # Optional (default: 300000)
PRICE_CACHE_DURATION=300000
# Minimum interval between upstream price fetches | integer milliseconds | # Optional (default: 90000)
MIN_REQUEST_INTERVAL=90000

# --- Auto-rebalancer ---
# Enables queue-backed automatic rebalance checks | boolean | # Optional (default: false)
ENABLE_AUTO_REBALANCER=false
# Scheduler interval for automatic rebalance checks | integer milliseconds | # Optional (default: 3600000)
AUTO_REBALANCE_CHECK_INTERVAL=3600000
# Minimum interval between successful rebalances per portfolio | integer milliseconds | # Optional (default: 86400000)
MIN_REBALANCE_INTERVAL=86400000
# Daily cap for automatic rebalances per portfolio | integer | # Optional (default: 3)
MAX_AUTO_REBALANCES_PER_DAY=3

# --- API rate limiting ---
# Sliding window for global API limits | integer milliseconds | # Optional (default: 60000)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per global window | integer | # Optional (default: 100)
RATE_LIMIT_MAX=100
# Max write requests (POST/PUT/DELETE) per window | integer | # Optional (default: 10)
RATE_LIMIT_WRITE_MAX=10
# Max auth requests per window | integer | # Optional (default: 5)
RATE_LIMIT_AUTH_MAX=5
# Max critical operation requests per window | integer | # Optional (default: 3)
RATE_LIMIT_CRITICAL_MAX=3
# Burst-protection window size | integer milliseconds | # Optional (default: 10000)
RATE_LIMIT_BURST_WINDOW_MS=10000
# Max global requests in burst window | integer | # Optional (default: 20)
RATE_LIMIT_BURST_MAX=20
# Max write requests in burst window | integer | # Optional (default: 3)
RATE_LIMIT_WRITE_BURST_MAX=3

# --- Queue and caching ---
# Redis URL for BullMQ queues/workers | URL | # Optional (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379
# Toggle in-memory portfolio cache for experiments | boolean | # Optional (default: false)
USE_MEMORY_CACHE=false

# --- Risk/circuit-breaker controls ---
# Drift/volatility threshold used by risk checks | percentage number | # Optional (default: 15)
VOLATILITY_THRESHOLD=15
# Maximum acceptable price age before data is considered stale | integer seconds | # Optional (default: 600)
PRICE_DATA_MAX_AGE=600
# Cooldown enforced between rebalances | integer hours | # Optional (default: 1)
REBALANCE_COOLDOWN_HOURS=1
# Max concentration for any single asset | percentage number | # Optional (default: 80)
MAX_SINGLE_ASSET_CONCENTRATION=80
# Max trade size relative to portfolio total value | percentage number | # Optional (default: 25)
MAX_TRADE_SIZE_PERCENTAGE=25
# Minimum trade amount threshold | decimal USD | # Optional (default: 10)
MIN_TRADE_SIZE_USD=10
# Max slippage for one trade | basis points | # Optional (default: 100)
REBALANCE_MAX_TRADE_SLIPPAGE_BPS=100
# Max aggregated slippage across full rebalance | basis points | # Optional (default: 250)
REBALANCE_MAX_TOTAL_SLIPPAGE_BPS=250
# Max bid/ask spread allowed for execution | basis points | # Optional (default: 120)
REBALANCE_MAX_SPREAD_BPS=120
# Minimum liquidity coverage multiplier required to trade | decimal number | # Optional (default: 1.0)
REBALANCE_MIN_LIQUIDITY_COVERAGE=1.0
# Allow partial fills during rebalance execution | boolean | # Optional (default: true)
REBALANCE_ALLOW_PARTIAL_FILL=true
# Roll back failed rebalances when possible | boolean | # Optional (default: true)
REBALANCE_ROLLBACK_ON_FAILURE=true

# --- Notifications ---
# SMTP host for outbound notification email | hostname | # Optional (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP port | integer | # Optional (default: 587)
SMTP_PORT=587
# Whether SMTP should use TLS from connect time | boolean | # Optional (default: false)
SMTP_SECURE=false
# SMTP username/login | string | # Optional (default: your-email@gmail.com)
SMTP_USER=your-email@gmail.com
# SMTP password or app password | string | # Optional (default: your-app-password)
SMTP_PASS=your-app-password
# Default sender email for notifications | email | # Optional (default: noreply@stellarportfolio.com)
SMTP_FROM=noreply@stellarportfolio.com
# Comma-separated admin signer addresses for privileged routes | CSV of Stellar public keys | # Optional (default: empty)
ADMIN_PUBLIC_KEYS=
# Outbound webhook request timeout | integer milliseconds | # Optional (default: 5000)
WEBHOOK_TIMEOUT=5000
# Number of webhook retries after first failure | integer | # Optional (default: 1)
WEBHOOK_RETRY_COUNT=1
# Delay between webhook retries | integer milliseconds | # Optional (default: 1000)
WEBHOOK_RETRY_DELAY=1000
# Max notifications per user per hour | integer | # Optional (default: 10)
NOTIFICATION_RATE_LIMIT_PER_HOUR=10

# --- CORS ---
# Browser origins allowed to call the API | CSV of URLs | # Optional (default: localhost origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# --- Logging ---
# Backend log verbosity | enum(debug|info|warn|error) | # Optional (default: info)
LOG_LEVEL=info
# Pretty-print logs instead of JSON lines | boolean | # Optional (default: false)
LOG_PRETTY=false
# Deployment environment label included in telemetry | string | # Optional (default: local)
LOG_DEPLOYMENT_ENV=local
# Enables verbose request/response API logging | boolean | # Optional (default: true)
ENABLE_API_LOGGING=true
# Enables verbose upstream price-feed logs | boolean | # Optional (default: false)
DEBUG_PRICE_FEEDS=false

# --- WebSocket ---
# Dedicated WebSocket port (typically same as HTTP port) | integer | # Optional (default: 3001)
WS_PORT=3001
# Interval for heartbeat ping/pong checks | integer milliseconds | # Optional (default: 30000)
WS_HEARTBEAT_INTERVAL=30000

# --- Risk score thresholds ---
# High-risk volatility threshold | percentage number | # Optional (default: 10)
RISK_VOLATILITY_HIGH=10
# Critical-risk volatility threshold | percentage number | # Optional (default: 15)
RISK_VOLATILITY_CRITICAL=15
# High-risk concentration threshold | percentage number | # Optional (default: 60)
RISK_CONCENTRATION_HIGH=60
# Critical-risk concentration threshold | percentage number | # Optional (default: 80)
RISK_CONCENTRATION_CRITICAL=80
# Low-liquidity threshold for warnings | decimal USD | # Optional (default: 1000)
RISK_LIQUIDITY_LOW=1000
# Critical-liquidity threshold | decimal USD | # Optional (default: 500)
RISK_LIQUIDITY_CRITICAL=500

# --- Analytics ---
# Background snapshot interval per portfolio | integer milliseconds | # Optional (default: 300000)
ANALYTICS_SNAPSHOT_INTERVAL=300000
# Max analytics snapshots retained per portfolio | integer | # Optional (default: 1000)
MAX_SNAPSHOTS_PER_PORTFOLIO=1000

# --- Security and auth ---
# JWT signing secret (must be >=32 chars to enable auth) | string | # Optional (default: empty; auth disabled)
JWT_SECRET=
# Previous JWT secret for rotation grace periods | string | # Optional (default: empty)
JWT_PREVIOUS_SECRET=
# Expiry timestamp for previous secret grace period | ISO8601 string | # Optional (default: empty)
JWT_PREVIOUS_SECRET_GRACE_UNTIL=
# Access token expiry | integer seconds | # Optional (default: 900)
JWT_ACCESS_EXPIRY_SEC=900
# Refresh token expiry | integer seconds | # Optional (default: 604800)
JWT_REFRESH_EXPIRY_SEC=604800
# API-level rate-limit window for security middleware | integer milliseconds | # Optional (default: 900000)
API_RATE_LIMIT_WINDOW=900000
# API-level rate-limit max requests in window | integer | # Optional (default: 100)
API_RATE_LIMIT_MAX_REQUESTS=100
# Request timeout for outbound/internal operations | integer milliseconds | # Optional (default: 30000)
REQUEST_TIMEOUT=30000
# Enable request schema validation | boolean | # Optional (default: true)
ENABLE_REQUEST_VALIDATION=true

# --- Feature flags and local development ---
# Enables demo portfolio behavior | boolean | # Optional (default: true in local template)
DEMO_MODE=true
# Permit fallback prices when primary feed fails | boolean | # Optional (default: true)
ALLOW_FALLBACK_PRICES=true
# Permit generated/mock historical market data | boolean | # Optional (default: true)
ALLOW_MOCK_PRICE_HISTORY=true
# Allow public/anonymous portfolios to be viewed in demo mode | boolean | # Optional (default: false)
ALLOW_PUBLIC_USER_PORTFOLIOS_IN_DEMO=false
# Enable debug/test route groups | boolean | # Optional (default: true)
ENABLE_DEBUG_ROUTES=true
# Allow demo balances when live balance fetch fails | boolean | # Optional (default: true)
ALLOW_DEMO_BALANCE_FALLBACK=true
# Seed demo data into local DB on first startup | boolean | # Optional (default: true)
ENABLE_DEMO_DB_SEED=true
# Starting USD amount for demo portfolios | decimal USD | # Optional (default: 10000)
DEMO_INITIAL_BALANCE=10000
# Mock external API providers for test/dev flows | boolean | # Optional (default: false)
MOCK_EXTERNAL_APIS=false

# --- Contract event indexer ---
# Soroban RPC URL for contract-event polling | URL | # Optional (default: network-specific Soroban RPC)
SOROBAN_RPC_URL=
# Backward-compatible alias for SOROBAN_RPC_URL | URL | # Optional (default: empty)
STELLAR_RPC_URL=
# Poll interval for on-chain event sync | integer milliseconds | # Optional (default: 15000)
SOROBAN_EVENT_INDEXER_INTERVAL_MS=15000
# Max events fetched per RPC page | integer | # Optional (default: 100)
SOROBAN_EVENT_INDEXER_LIMIT=100
# Ledger lookback on first sync when cursor is absent | integer ledgers | # Optional (default: 500)
SOROBAN_EVENT_INDEXER_BOOTSTRAP_WINDOW=500
# Max pages consumed per sync cycle | integer | # Optional (default: 10)
SOROBAN_EVENT_INDEXER_MAX_PAGES=10
# Declared contract event schema version to enforce compatibility | integer | # Optional (default: 1)
CONTRACT_EVENT_SCHEMA_VERSION=1

# --- Observability ---
# Enable backend Sentry integration | boolean | # Optional (default: false)
SENTRY_ENABLED=false
# Sentry DSN for error reporting | URL | # Optional (default: empty)
SENTRY_DSN=
# Sentry environment tag | string | # Optional (default: development)
SENTRY_ENVIRONMENT=development
# Sentry release tag | string | # Optional (default: empty)
SENTRY_RELEASE=
# Sentry traces sampling rate | decimal number | # Optional (default: 0.2)
SENTRY_TRACES_SAMPLE_RATE=0.2
# Sentry profiling sampling rate | decimal number | # Optional (default: 0.1)
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Enable New Relic APM integration | boolean | # Optional (default: false)
NEW_RELIC_ENABLED=false
# New Relic service name | string | # Optional (default: stellar-portfolio-backend)
NEW_RELIC_APP_NAME=stellar-portfolio-backend
# New Relic license key | string | # Optional (default: empty)
NEW_RELIC_LICENSE_KEY=
# Enable New Relic distributed tracing | boolean | # Optional (default: true)
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
# New Relic log destination | string | # Optional (default: stdout)
NEW_RELIC_LOG=stdout
# Expose /metrics endpoint for Prometheus | boolean | # Optional (default: true)
METRICS_ENABLED=true
# Prefix for all emitted metric names | string | # Optional (default: stellar_portfolio_)
METRICS_PREFIX=stellar_portfolio_
# Default service label attached to emitted metrics | string | # Optional (default: stellar-portfolio-backend)
METRICS_DEFAULT_LABELS_SERVICE=stellar-portfolio-backend
# Optional contact label for alert routing metadata | string | # Optional (default: platform-oncall)
ALERT_CONTACT=platform-oncall
