{
    "name": "stellar-portfolio-backend",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --import ./src/observability/apm-register.ts src/index.ts",
        "build": "tsc",
        "start": "node --import ./dist/observability/apm-register.js dist/index.js",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:migrate:dry-run": "tsx src/db/migrate.ts -- --dry-run",
        "db:migrate:rollback": "tsx src/db/migrate.ts -- --rollback",
        "db:migrate:status": "tsx src/db/migrate.ts -- --status",
        "db:setup": "tsx src/db/migrate.ts",
        "db:seed:e2e": "tsx src/db/seed.e2e.ts",

        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ci": "npm run test:coverage",
        "test:shard": "vitest run --coverage --reporter=blob",
        "test:merge-coverage": "vitest run --merge-reports --coverage",
        "audit:policy": "node ../scripts/check-npm-audit-baseline.mjs backend",
        "test:rate-limits": "node scripts/test-rate-limits.js",
        "test:notifications:dev": "node scripts/test-notifications-dev.mjs",
        "openapi:export": "tsx scripts/export-openapi.ts",
        "spec:check": "npm run openapi:export && git diff --exit-code -- openapi.json",
"snapshots:regenerate": "tsx scripts/regenerate-rebalance-snapshots.ts",
"replay:verify": "tsx scripts/verify-replay.ts validate",
"replay:run": "tsx scripts/verify-replay.ts replay",
        "api:validate": "tsx scripts/validate-api-docs.ts",
        "indexer:reindex": "tsx scripts/reindex-events.ts"
    },
    "dependencies": {
        "@sentry/node": "^10.56.0",
        "@sentry/profiling-node": "^10.56.0",
        "@stellar/stellar-sdk": "^15.1.0",
        "better-sqlite3": "^12.10.0",
        "bullmq": "^5.78.0",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "ioredis": "^5.9.3",
        "jsonwebtoken": "^9.0.3",
        "newrelic": "^14.1.0",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.10",
        "pdfkit": "^0.18.0",
        "pg": "^8.21.0",
        "pino": "^10.3.1",
        "prom-client": "^15.1.3",
        "rate-limit-redis": "^5.0.0",
        "swagger-ui-express": "^5.0.1",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.2",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^8.0.0",
        "@types/pdfkit": "^0.17.6",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/ws": "^8.18.1",
        "@vitest/coverage-v8": "^4.1.8",
        "supertest": "^7.2.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    }
}
