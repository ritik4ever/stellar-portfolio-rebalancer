{
    "name": "stellar-portfolio-backend",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --import ./src/observability/register-tracing.ts --import ./src/observability/apm-register.ts src/index.ts",
        "build": "tsc",
        "start": "node --import ./dist/observability/register-tracing.js --import ./dist/observability/apm-register.js dist/index.js",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:migrate:dry-run": "tsx src/db/migrate.ts -- --dry-run",
        "db:migrate:rollback": "tsx src/db/migrate.ts -- --rollback",
        "db:migrate:status": "tsx src/db/migrate.ts -- --status",
        "db:setup": "tsx src/db/migrate.ts",
        "db:seed:e2e": "tsx src/db/seed.e2e.ts",

        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ci": "npm run test:coverage",
        "test:shard": "vitest run --coverage --reporter=blob",
        "test:merge-coverage": "vitest run --merge-reports --coverage",
        "test:memory-leak": "clinic doctor -- node --import ./dist/observability/apm-register.js ./scripts/memory-leak-test.mjs",
        "perf:baseline": "clinic doctor --collect-only -- npm start",
        "perf:analyze": "node ./scripts/analyze-clinic-report.mjs",
        "audit:policy": "node ../scripts/check-npm-audit-baseline.mjs backend",
        "test:rate-limits": "node scripts/test-rate-limits.js",
        "test:notifications:dev": "node scripts/test-notifications-dev.mjs",
        "openapi:export": "tsx scripts/export-openapi.ts",
        "spec:check": "npm run openapi:export && git diff --exit-code -- openapi.json",
        "snapshots:regenerate": "tsx scripts/regenerate-rebalance-snapshots.ts",
        "replay:verify": "tsx scripts/verify-replay.ts validate",
        "replay:run": "tsx scripts/verify-replay.ts replay",
        "sdk:generate": "tsx scripts/generate-sdk.ts",
        "api:validate": "tsx scripts/validate-api-docs.ts",
        "indexer:reindex": "tsx scripts/reindex-events.ts"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
        "@opentelemetry/instrumentation": "^0.219.0",
        "@opentelemetry/instrumentation-express": "^0.67.0",
        "@opentelemetry/instrumentation-http": "^0.219.0",
        "@opentelemetry/resources": "^2.8.0",
        "@opentelemetry/sdk-node": "^0.219.0",
        "@opentelemetry/semantic-conventions": "^1.41.1",
        "@sentry/node": "^10.62.0",
        "@sentry/profiling-node": "^10.62.0",
        "@stellar/stellar-sdk": "^16.0.1",
        "better-sqlite3": "^12.11.1",
        "bullmq": "^5.79.2",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "ioredis": "^5.9.3",
        "jsonwebtoken": "^9.0.3",
        "newrelic": "^14.1.2",
        "node-cron": "^4.5.0",
        "nodemailer": "^9.0.3",
        "pdfkit": "^0.19.1",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "prom-client": "^15.1.3",
        "rate-limit-redis": "^5.0.0",
        "swagger-ui-express": "^5.0.1",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.0.1",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^8.0.1",
        "@types/pdfkit": "^0.17.6",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/ws": "^8.18.1",
        "@vitest/coverage-v8": "^4.1.9",
        "ioredis-mock": "^8.13.1",
        "js-yaml": "^5.2.0",
        "openapi-typescript": "^7.8.0",
        "redis-memory-server": "^0.17.0",
        "supertest": "^7.2.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    }
}
